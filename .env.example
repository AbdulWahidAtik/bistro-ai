# GEMINI_API_KEY: Optional in local dev. When empty, AI endpoints return fallback text.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# APP_URL: Public URL for deployed app links, callbacks, and reports.
APP_URL="http://localhost:3000"

# VITE_API_URL: Public backend URL for deployed frontend builds.
# Leave empty in local dev so Vite can proxy /api requests.
VITE_API_URL=""

# CORS_ORIGINS: Comma-separated browser origins allowed to call the API.
# Defaults to APP_URL when empty.
CORS_ORIGINS="http://localhost:3000"

# API_PORT: Local Express API port.
API_PORT="3001"

# SERVE_STATIC: Set true after npm run build to serve dist/ from the Express app.
SERVE_STATIC="false"

# REQUEST_LOGGING: Set false to disable JSON request logs.
REQUEST_LOGGING="true"

# In-memory rate limits. Tune per deployment size, or set RATE_LIMIT_ENABLED=false to disable.
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="300"
AUTH_RATE_LIMIT_MAX="10"
AI_RATE_LIMIT_MAX="30"

# Optional role-based auth. Leave ADMIN_PASSWORD empty to keep auth disabled in local dev.
# Set ADMIN_PASSWORD in staging/production to create the first admin account.
# Additional admin/manager/staff accounts are managed from Settings > Access.
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""
# In production, AUTH_SECRET must be at least 32 characters and different from ADMIN_PASSWORD.
AUTH_SECRET="replace-with-a-long-random-secret-before-enabling-auth"
AUTH_TOKEN_TTL_MS="86400000"

# Optional demo seed credentials used by npm run seed:demo.
DEMO_ADMIN_USERNAME="admin"
DEMO_ADMIN_PASSWORD="AdminPass123!"
DEMO_MANAGER_USERNAME="manager"
DEMO_MANAGER_PASSWORD="ManagerPass123!"
DEMO_STAFF_USERNAME="staff"
DEMO_STAFF_PASSWORD="StaffPass123!"

# MONGODB_URI: Optional MongoDB database URI. When set, the API uses MongoDB.
# Local example: mongodb://127.0.0.1:27017/bistro-ai
# Atlas example: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/bistro-ai
MONGODB_URI=""

# DATA_FILE: JSON fallback store used when MONGODB_URI is empty.
DATA_FILE="data/bistro-ai.json"
